# ========== 模式切换 ==========
# local: DeepSeek API + 本地 HuggingFace Embedding
# cloud: Ollama Chat + Ollama Embedding
RUN_MODE=local

# ========== Local 模式 ==========
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# ========== Cloud 模式 ==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:14b
OLLAMA_EMBEDDING_MODEL=bge-m3

# ========== 通用配置 ==========
DATABASE_URL=postgresql://postgres:123456@localhost:5432/enterprisemind
CHROMA_PERSIST_DIR=./chroma_db

# ========== 可选功能 ==========
TAVILY_API_KEY=

# ========== LangSmith（可选） ==========
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=enterprisemind
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_FAIL_OPEN=true
LANGSMITH_PRECHECK_TIMEOUT_SEC=2.0

# ========== 服务配置 ==========
HOST=127.0.0.1
PORT=7860
DEBUG=false

# ========== 功能开关 ==========
ENABLE_RERANK=true
ENABLE_SELF_RAG=true
ENABLE_SELF_RAG_GUARD=true
ENABLE_QUERY_OPTIMIZATION=true
REACT_MAX_STEPS=3

# ========== HITL ==========
HITL_AMBIGUITY_CONFIDENCE_LEVEL=medium
HITL_REQUIRE_CONFIRM_ON_DUAL_ROUTE=true
HITL_ENABLE_LOW_CONF_CONFIRM=true
