# ========================
# Core Mode
# local: DeepSeek API + local HuggingFace embedding
# cloud: Ollama chat + Ollama embedding
# ========================
RUN_MODE=local

# ========================
# Model Config
# local mode required:
#   DEEPSEEK_API_KEY
# cloud mode required:
#   OLLAMA_BASE_URL
#   OLLAMA_MODEL
#   OLLAMA_EMBEDDING_MODEL
# ========================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:14b
OLLAMA_EMBEDDING_MODEL=bge-m3

# ========================
# Storage
# ========================
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/enterprisemind
POSTGRES_PASSWORD=change_me
CHROMA_PERSIST_DIR=./chroma_db

# ========================
# LLM Cache
# Supported: none / memory / redis
# LangChain 1.x global cache is configured via set_llm_cache(...)
# ========================
PERSISTENT_CACHE_BACKEND=sqlite
PERSISTENT_CACHE_DB_PATH=./cache/persistent_cache.db
PERSISTENT_CACHE_TTL_SECONDS=3600
PERSISTENT_CACHE_REDIS_PREFIX=persistent_cache:

LLM_CACHE_BACKEND=none
LLM_CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379/0
LLM_CACHE_FAIL_OPEN=true

# ========================
# Optional External Tools
# ========================
TAVILY_API_KEY=

# ========================
# LangSmith Optional
# ========================
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=enterprisemind-demo
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_FAIL_OPEN=true
LANGSMITH_PRECHECK_TIMEOUT_SEC=2.0

# ========================
# Service
# FastAPI and optional Gradio demo both read HOST/PORT
# ========================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ========================
# Workflow Flags
# ========================
AGENT_MODE=worker_react
ENABLE_RERANK=true
ENABLE_SELF_RAG=true
ENABLE_SELF_RAG_GUARD=true
ENABLE_QUERY_OPTIMIZATION=true
ENABLE_LLM_INTENT_ROUTING=true
RERANK_MODEL=BAAI/bge-reranker-base
REACT_MAX_STEPS=3

# ========================
# HITL
# ========================
HITL_AMBIGUITY_CONFIDENCE_LEVEL=medium
HITL_REQUIRE_CONFIRM_ON_DUAL_ROUTE=true
HITL_ENABLE_LOW_CONF_CONFIRM=true
